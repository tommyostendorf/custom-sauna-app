    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/web-push": "^3.6.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
