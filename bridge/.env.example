# Copy this file to ".env" and fill in your values.

# The sauna's IP address on your local network.
# Found during Phase 0 testing. Pin it with a DHCP reservation in the Google Home app
# so it never changes.
SAUNA_HOST=192.168.86.48

# Port the bridge HTTP API listens on.
PORT=8787

# Shared secret. The PWA must send this as "Authorization: Bearer <token>".
# Leave blank to disable auth (only safe on a trusted local network).
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
BRIDGE_TOKEN=

# Comma-separated list of allowed browser origins for CORS (the PWA's URL).
# Use * to allow any origin (fine for local testing).
ALLOWED_ORIGINS=*

# Which network interface the bridge binds to.
# Default (127.0.0.1) = localhost only: the only way in is via Tailscale, so other
# devices on your WiFi can't reach the bridge. Recommended, since there's no auth by
# default and this controls a heater.
# Set to 0.0.0.0 only if you deliberately want any device on the local network to
# reach it (e.g. testing without Tailscale).
BIND_HOST=127.0.0.1
